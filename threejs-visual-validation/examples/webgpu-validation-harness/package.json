{
  "name": "threejs-webgpu-validation-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "node src/validate.js",
    "validate:v1": "node src/validate.js",
    "validate:v2": "node src/validate-v2.js",
    "validate:unit": "node src/validate-v2.js",
    "test:mutations": "node src/v2-self-test.js && node --test src/png.test.js src/raw-capture-manifest.test.js",
    "test:routes": "node --test src/*.test.js",
    "test:physical": "node --test src/immutable-physical-build.test.js src/immutable-physical-server.test.js src/physical-lane-join.test.js src/physical-runtime-profile.test.js src/physical-session-validator.test.js src/route-locks.test.js",
    "capture": "node src/capture-correctness.js",
    "capture:evidence": "node src/capture-correctness.js",
    "capture:physical": "node src/immutable-physical-server.js",
    "physical:build": "node src/immutable-physical-build.js",
    "physical:serve": "node src/immutable-physical-server.js",
    "physical:import": "node src/in-app-evidence-import.js",
    "physical:validate": "node src/physical-validate-record.js",
    "evidence:readiness": "node src/evidence-readiness.js",
    "validate:artifacts": "node src/validate-browser-artifacts.js --bundle release",
    "validate:raw": "node src/validate-browser-artifacts.js --bundle raw --profile correctness",
    "validate:quick": "npm run check && npm run test:routes && npm run test:mutations",
    "validate:full": "npm run check && npm run test:routes && npm run validate:v1 && npm run validate:v2 && npm run validate:artifacts",
    "check": "node --check src/*.js src/schema/*.js && node src/check-imports.mjs"
  },
  "dependencies": {
    "three": "0.185.1"
  }
}
