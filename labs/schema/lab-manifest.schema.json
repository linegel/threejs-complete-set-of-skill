{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linegel.github.io/threejs-complete-set-of-skill/schemas/lab-manifest-v2.json",
  "title": "Three.js native-WebGPU lab manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "skill",
    "threeRevision",
    "kind",
    "status",
    "canonicalSource",
    "browserEntry",
    "publishPath",
    "scenarios",
    "mechanisms",
    "tiers",
    "modes",
    "cameras",
    "seeds",
    "capabilityRequirements",
    "runtimeProof",
    "evidenceContract",
    "validationCommand",
    "sourceHash",
    "proxyStatus"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "skill": { "type": "string", "pattern": "^threejs-[a-z0-9-]+$" },
    "threeRevision": { "const": "0.185.1" },
    "kind": { "$ref": "#/$defs/demoKind" },
    "status": { "$ref": "#/$defs/acceptanceStatus" },
    "canonicalSource": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repoPath" }
    },
    "browserEntry": {
      "oneOf": [
        { "$ref": "#/$defs/repoPath" },
        { "type": "null" }
      ]
    },
    "publishPath": {
      "oneOf": [
        { "type": "string", "pattern": "^/demos/[a-z0-9][a-z0-9-]*/$" },
        { "type": "null" }
      ]
    },
    "scenarios": {
      "type": "array",
      "items": { "$ref": "#/$defs/route" }
    },
    "mechanisms": {
      "type": "array",
      "items": { "$ref": "#/$defs/route" }
    },
    "tiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualityTier" }
    },
    "modes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "cameras": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "seeds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
    },
    "capabilityRequirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "runtimeProof": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "evidenceContract": { "type": "string", "enum": ["v2", "none"] },
    "evidenceBundle": {
      "oneOf": [
        { "$ref": "#/$defs/repoPath" },
        { "type": "null" }
      ]
    },
    "validationCommand": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "commands": { "$ref": "#/$defs/commands" },
    "sourceHash": {
      "oneOf": [
        { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        { "type": "null" }
      ]
    },
    "proxyStatus": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["limitation", "canonicalLabId"],
          "properties": {
            "limitation": { "type": "string", "minLength": 1 },
            "canonicalLabId": {
              "oneOf": [
                { "$ref": "#/$defs/id" },
                { "type": "null" }
              ]
            }
          }
        }
      ]
    },
    "nonRenderingScenarioSuite": { "type": "boolean" },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": { "type": "array" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1
    },
    "routeId": {
      "type": "string",
      "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))[a-z0-9](?:[a-z0-9./-]*[a-z0-9])?$",
      "minLength": 1
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "demoKind": {
      "type": "string",
      "enum": [
        "canonical-lab",
        "mechanism-demo",
        "tier-demo",
        "integration-demo",
        "proxy-demo",
        "generated-asset-demo",
        "legacy-deprecated",
        "contract-fixture"
      ]
    },
    "acceptanceStatus": {
      "type": "string",
      "enum": ["accepted", "incomplete", "blocked", "secondary", "not-applicable"]
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/routeId" },
        "title": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "startup": { "type": "object" },
        "acceptanceStatus": { "$ref": "#/$defs/acceptanceStatus" }
      }
    },
    "qualityTier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "targetClass",
        "frameTargetMs",
        "resolutionPolicy",
        "mechanismLimits",
        "resourceLimits",
        "degradationFromPrevious",
        "preservedInvariants",
        "acceptanceStatus"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/routeId" },
        "targetClass": { "type": "string", "minLength": 1 },
        "frameTargetMs": {
          "oneOf": [
            { "$ref": "#/$defs/numericDatum" },
            { "type": "null" }
          ]
        },
        "resolutionPolicy": { "type": "object" },
        "mechanismLimits": { "type": "object" },
        "resourceLimits": { "type": "object" },
        "degradationFromPrevious": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "preservedInvariants": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptanceStatus": { "$ref": "#/$defs/acceptanceStatus" }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "required"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "required": { "type": "boolean" },
        "evidence": { "type": ["string", "null"] },
        "status": { "$ref": "#/$defs/acceptanceStatus" },
        "acceptanceStatus": { "$ref": "#/$defs/acceptanceStatus" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "check": { "type": "string", "minLength": 1 },
        "test": { "type": "string", "minLength": 1 },
        "mutations": { "type": "string", "minLength": 1 },
        "capture": { "type": "string", "minLength": 1 },
        "validateArtifacts": { "type": "string", "minLength": 1 },
        "validateQuick": { "type": "string", "minLength": 1 },
        "validateFull": { "type": "string", "minLength": 1 }
      }
    },
    "numericDatum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "label", "source"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "enum": ["Authored", "Derived", "Measured", "Gated"] },
        "source": { "type": "string", "minLength": 1 },
        "uncertainty": { "type": "string", "minLength": 1 }
      }
    }
  }
}
