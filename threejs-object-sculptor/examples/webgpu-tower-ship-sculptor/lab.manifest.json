  "capabilityRequirements": [
    {
      "id": "native-webgpu",
      "required": true,
      "evidence": "The controller awaits WebGPURenderer.init() and rejects any backend where isWebGPUBackend is not true; no fallback is activated.",
      "status": "accepted"
    }
  ],
  "runtimeProof": [
    {
      "id": "renderer-init",
      "required": true,
      "evidence": "Await createTowerShipLabController(), which awaits renderer.init() before exposing labController.",
      "status": "accepted"
    },
    {
      "id": "backend-is-webgpu",
      "required": true,
      "evidence": "Capture getMetrics().nativeWebGPU === true from the initialized controller.",
      "status": "accepted"
    },
    {
      "id": "mechanism-reachable",
      "required": true,
      "evidence": "Load every physical mechanism route and reconcile the locked path against the selected runtime mode.",
      "status": "accepted"
    },
    {
      "id": "semantic-object-contract",
      "required": true,
      "evidence": "Capture node, socket, collider, destruction-group, and 24-oar inventories from root.userData.sculptRuntime.",
      "status": "accepted"
    },
    {
      "id": "aligned-readback",
      "required": true,
      "evidence": "Capture RGBA8 render-target pixels with the controller-reported integer 256-byte row stride.",
      "status": "accepted"
    },
    {
      "id": "render-or-compute-work",
      "required": true,
      "evidence": "Accepted publishable release-bundle proves render-or-compute-work for webgpu-tower-ship-sculptor.",
