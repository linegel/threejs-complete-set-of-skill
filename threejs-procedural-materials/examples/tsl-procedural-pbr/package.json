{
  "name": "threejs-tsl-procedural-pbr",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check *.js && node --check *.mjs",
    "validate": "npm run validate:quick",
    "validate:unit": "node validate-procedural-pbr.mjs && node validate-routes.mjs",
    "test:mutations": "node validate-material-mutations.mjs",
    "capture": "node capture.mjs",
    "validate:artifacts": "node validate-material-artifacts.mjs",
    "validate:quick": "npm run validate:unit && npm run test:mutations",
    "validate:full": "npm run check && npm run validate:quick && npm run validate:artifacts",
    "validate:generated-assets": "node validate-generated-lava-causes.mjs"
  },
  "dependencies": {
    "playwright": "1.61.1",
    "three": "0.185.1"
  }
}
