  "capabilityRequirements": [
    {
      "id": "native-webgpu",
      "required": true,
      "evidence": "Native browser capture: renderer.backend.isWebGPUBackend after init; capture-session records backend=webgpu on WebGPURenderer r185.",
      "status": "accepted"
    },
    {
      "id": "rgba16float-storage",
      "required": true,
      "evidence": "field-storage-readback.json records RGBA16F storage bake and mip chain readbacks from the native capture.",
      "status": "accepted"
    },
    {
      "id": "storage-buffer",
      "required": true,
      "evidence": "field-placement-readback.json records structured placement storage-buffer contents from the native capture.",
      "status": "accepted"
    }
  ],
  "runtimeProof": [
    {
      "id": "backend-is-webgpu",
      "required": true,
      "evidence": "capture-session.json runtime.metrics.backend=webgpu and nativeWebGPU=true from playwright-headless Chrome WebGPU.",
      "status": "accepted"
    },
    {
      "id": "direct-f32-readback",
      "required": true,
      "evidence": "field-readback.json + field-probe-corpus.json from controller.captureFieldReadback / captureProbeCorpusReadback.",
