{
  "name": "threejs-webgpu-skill-pack",
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "description": "Agent skill pack for Three.js WebGPU/TSL procedural graphics, image pipelines, and visual validation.",
  "engines": {
    "node": "22.22.0",
    "npm": "10.9.4"
  },
  "files": [
    "skills/",
    "threejs-*/SKILL.md",
    "threejs-*/references/",
    "threejs-*/assets/",
    "threejs-object-sculptor/scripts/*.py",
    "!threejs-object-sculptor/scripts/test_*.py",
    "skills.sh.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "toolchain:preflight": "node scripts/toolchain-preflight.mjs",
    "browser:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "build:pages": "npm run pages:build",
    "labs:registry": "node scripts/validate-lab-manifests.mjs --write-registry",
    "labs:check": "node scripts/validate-lab-manifests.mjs && node scripts/check-lab-implementation-matrix.mjs && node scripts/check-lab-sources.mjs && node scripts/check-capture-wiring.mjs && node --test tests/labs/*.test.mjs && node scripts/run-labs.mjs check",
    "labs:test": "node scripts/run-labs.mjs test",
    "labs:test:unit": "node --test tests/labs/*.test.mjs",
    "labs:test:mutations": "node --test tests/labs/*.test.mjs && node scripts/run-labs.mjs mutations",
    "labs:capture": "node scripts/run-labs.mjs capture",
    "labs:capture:browser": "node scripts/capture-lab-browser.mjs",
    "labs:assemble:validation-harness": "node scripts/assemble-validation-harness-release.mjs",
    "labs:validate": "node scripts/run-labs.mjs validate",
    "labs:validate:quick": "node scripts/validate-lab-manifests.mjs && node scripts/run-labs.mjs quick",
    "labs:validate:full": "node scripts/validate-lab-manifests.mjs && node scripts/run-labs.mjs full",
    "pages:build": "node scripts/build-pages.mjs && node scripts/generate-seo-images.mjs && node scripts/build-lab-pages.mjs && node scripts/build-evidence-pages.mjs && node scripts/generate-responsive-images.mjs && node scripts/validate-site-presentation.mjs && node scripts/validate-site-seo.mjs",
    "pages:build-evidence": "node scripts/build-evidence-pages.mjs",
    "pages:generate-seo-images": "node scripts/generate-seo-images.mjs",
    "pages:generate-responsive-images": "node scripts/generate-responsive-images.mjs",
    "pages:capture-previews": "node scripts/capture-site-previews.mjs --primary-only",
    "pages:promote-evidence": "node scripts/promote-runtime-evidence.mjs",
    "pages:refresh-previews": "node scripts/build-pages.mjs && node scripts/build-lab-pages.mjs && node scripts/capture-site-previews.mjs --primary-only && node scripts/build-pages.mjs && node scripts/generate-seo-images.mjs && node scripts/build-lab-pages.mjs && node scripts/build-evidence-pages.mjs && node scripts/generate-responsive-images.mjs && node scripts/validate-site-presentation.mjs && node scripts/validate-site-seo.mjs",
    "pages:smoke": "node scripts/pages-smoke.mjs",
    "pages:audit-live": "node scripts/audit-live-site-seo.mjs",
    "pages:audit-presentation": "node scripts/audit-live-presentation.mjs",
    "pages:validate-presentation": "node scripts/validate-site-presentation.mjs",
    "pages:validate-seo": "node scripts/validate-site-seo.mjs",
    "pages:validate-source-hashes": "node scripts/validate-pages-source-hashes.mjs",
    "skills:list": "npx skills@latest add linegel/threejs-complete-set-of-skill --list",
    "skills:sync": "node scripts/sync-skill-distribution.mjs",
    "skills:check": "node scripts/validate-skills-manifest.mjs && node scripts/validate-skill-distribution.mjs && node --test tests/skills/*.test.mjs",
    "skills:pack": "npm run skills:check && npm pack",
    "skills:pack:dry-run": "npm run skills:check && npm pack --dry-run --json --ignore-scripts",
    "test:skills": "npm run skills:check",
    "check:all": "npm run skills:check && npm run labs:check && npm run pages:build",
    "test": "npm run skills:check"
  },
  "keywords": [
    "skills",
    "agent-skills",
    "codex",
    "claude-code",
    "threejs",
    "three.js",
    "webgpu",
    "tsl",
    "procedural-graphics",
    "visual-validation"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linegel/threejs-complete-set-of-skill.git"
  },
  "homepage": "https://threejs-skills.com/",
  "bugs": {
    "url": "https://github.com/linegel/threejs-complete-set-of-skill/issues"
  },
  "license": "ISC",
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "marked": "18.0.5",
    "playwright": "1.61.1",
    "sharp": "0.35.3",
    "vite": "8.1.3"
  }
}
